    "coverage": "vitest run --coverage",
    "build:corpus": "node scripts/build-corpus.mjs"
  },
  "dependencies": {
    "@capacitor-community/keep-awake": "^8.0.1",
    "@capacitor-community/speech-recognition": "^7.0.1",
